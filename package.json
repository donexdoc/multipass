{
  "name": "multipass",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "db:generate": "pnpm --filter @multipass/prisma db:generate",
    "db:migrate": "pnpm --filter @multipass/prisma db:migrate",
    "db:studio": "pnpm --filter @multipass/prisma db:studio"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "prettier": "^3.8.3",
    "turbo": "^2.9.16",
    "typescript": "^5.0.0"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "pnpm": {
    "supportedArchitectures": {
      "os": ["linux", "win32", "darwin"],
      "cpu": ["x64", "arm64"],
      "libc": ["glibc", "musl"]
    }
  }
}
