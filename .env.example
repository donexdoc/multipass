# Database
DATABASE_URL=postgresql://multipass:password@localhost:5432/multipass

# Auth
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-refresh-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# App
PORT=4000
CORS_ORIGIN=http://localhost:5173

# Seed — first admin user (created on startup if not exists)
ADMIN_LOGIN=admin
ADMIN_PASSWORD=Admin123!

# Setup endpoint — one-time initialization via secret URL
# POST /api/setup/:secretPath  →  creates first admin + seed data
# Endpoint returns 403 after first user is created (or if env is not set)
SETUP_SECRET_PATH=
