# Database
DATABASE_URL=postgresql://multipass:password@localhost:5432/multipass

# Auth
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-refresh-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# App
PORT=4000
CORS_ORIGIN=http://localhost:5173

# Seed — first admin user (created on startup if not exists)
ADMIN_LOGIN=admin
ADMIN_PASSWORD=Admin123!

# GoBGP (optional — only needed if using BGP announcements, run with --profile bgp)
# IMAGE_GOBGP=registry.example.com/project/gobgp  # если не задано — Docker соберёт локально из Dockerfile.gobgp
# GOBGP_ROUTER_ID=192.168.1.10   # IP этой VM в LAN (BGP router-id)
# GOBGP_LOCAL_AS=65000           # локальный AS
# GOBGP_PEER_IP=192.168.1.1      # IP MikroTik (BGP peer)
# GOBGP_PEER_AS=65001            # AS MikroTik
# BGP_GOBGP_API_URL defaults to host.docker.internal:50051 — change only if GoBGP runs elsewhere
